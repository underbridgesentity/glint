# ── Supabase ──
# Provision the project in the EU region nearest SA (eu-west-2 London / eu-west-1
# Ireland / eu-central-1 Frankfurt — pick lowest ping). POPIA-compliant with user
# consent + GDPR adequacy. Standard Postgres, so portable to Cape Town later.
# Get these from: Supabase dashboard → Project Settings → API
# Expo apps read EXPO_PUBLIC_*, Next.js apps read NEXT_PUBLIC_*. Keep both in sync.

EXPO_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-ref.supabase.co"
EXPO_PUBLIC_SUPABASE_ANON_KEY="YOUR-ANON-KEY"

NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR-ANON-KEY"

# Server-only (never ship to client). Used by admin server actions / webhooks.
SUPABASE_SERVICE_ROLE_KEY="YOUR-SERVICE-ROLE-KEY"

# ── Payments (Yoco — SA-native) ──
YOCO_SECRET_KEY=""
YOCO_WEBHOOK_SECRET=""

# ── WhatsApp Business (native booking + notifications) ──
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_VERIFY_TOKEN=""
