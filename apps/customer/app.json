{
  "expo": {
    "name": "Glint",
    "slug": "glint-customer",
    "version": "0.1.0",
    "scheme": "glint",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "backgroundColor": "#0C0C0C",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#0C0C0C",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "co.za.glint.customer",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Glint uses your camera to add a photo of your vehicle.",
        "NSPhotoLibraryUsageDescription": "Glint lets you choose a vehicle photo from your library.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "co.za.glint.customer",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0C0C0C"
      },
      "permissions": ["CAMERA"]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router", "expo-font"],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "privacyPolicyUrl": "https://glint-blond.vercel.app/privacy",
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    },
    "owner": "REPLACE_WITH_EXPO_USERNAME"
  }
}
