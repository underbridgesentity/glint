{
  "expo": {
    "name": "Glint",
    "slug": "glint-customer",
    "version": "0.1.0",
    "scheme": "glint",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "backgroundColor": "#0C0C0C",
    "icon": "./assets/icon.png",
    "splash": {
      "backgroundColor": "#0C0C0C",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "co.za.glint.customer"
    },
    "android": {
      "package": "co.za.glint.customer",
      "adaptiveIcon": {
        "backgroundColor": "#0C0C0C"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": ["expo-router", "expo-font"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
