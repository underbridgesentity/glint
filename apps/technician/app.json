{
  "expo": {
    "name": "Glint Tech",
    "slug": "glint-technician",
    "version": "0.1.0",
    "scheme": "glinttech",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "backgroundColor": "#0C0C0C",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#0C0C0C",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "co.za.glint.technician",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Glint Tech uses your camera to capture before-and-after proof photos of each wash.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "co.za.glint.technician",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0C0C0C"
      },
      "permissions": ["CAMERA"]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router", "expo-font"],
    "experiments": { "typedRoutes": false },
    "extra": {
      "privacyPolicyUrl": "https://glint-blond.vercel.app/privacy",
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    },
    "owner": "REPLACE_WITH_EXPO_USERNAME"
  }
}
